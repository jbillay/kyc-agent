# KYC Agent Backend — Environment Variables
# Copy this file to .env and adjust values for your environment.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# TCP port the server listens on
PORT=4000

# Bind address (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Controls stack trace exposure in error responses (development | production)
NODE_ENV=development

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Single allowed CORS origin (credentials-enabled)
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# Connection string used by node-pg-migrate and db/connection.js
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://kyc:kyc@localhost:5432/kyc_agent

# Set to "false" to skip automatic migration on startup
RUN_MIGRATIONS_ON_START=true

# ---------------------------------------------------------------------------
# Redis (BullMQ job queue)
# ---------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# MinIO (document storage)
# ---------------------------------------------------------------------------

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Ollama (LLM inference — default provider)
# ---------------------------------------------------------------------------

OLLAMA_BASE_URL=http://localhost:11434
