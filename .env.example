# KYC Agent — Environment Configuration
# Copy this file to .env and override values as needed.
# All variables are optional — Docker Compose applies the defaults shown here.
#
# _HOST variables control the network interface each port binds to.
#   127.0.0.1 = localhost only (default, secure for development)
#   0.0.0.0   = all interfaces (enables remote access — see warning below)
#
# ⚠  WARNING: If you set any _HOST to 0.0.0.0, you MUST change the default
#    credentials below. Never expose services with default passwords.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
PG_USER=kyc
PG_PASSWORD=kyc                    # ⚠ Change in production
PG_DB=kycagent
PG_HOST=127.0.0.1
PG_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin        # ⚠ Change in production
MINIO_SECRET_KEY=minioadmin        # ⚠ Change in production
MINIO_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_HOST=127.0.0.1
MINIO_CONSOLE_PORT=9001

# ── Ollama (LLM Inference) ───────────────────────────────────────────────────
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=4000
JWT_SECRET=change-me-in-production # ⚠ Change in production
NODE_ENV=development               # Set to "production" for production deployments

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000

# ── Agent Workers ────────────────────────────────────────────────────────────
AGENT_WORKER_REPLICAS=2            # Number of parallel agent-worker containers
